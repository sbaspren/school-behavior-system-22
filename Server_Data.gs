// DATA FETCHING - جلب البيانات (الإصدار الكامل والذكي)
// =================================================================

function getInitialData() {
  try {
    // ★ فحص: هل تم إعداد هيكل المدرسة؟
    if (!isStructureConfigured_()) {
      return {
        success: true,
        needsSetup: true,
        message: 'يرجى إعداد هيكل المدرسة أولاً من الإعدادات'
      };
    }

    // ★ تهيئة تلقائية: تأكد من وجود كل الشيتات (تعمل مرة واحدة كل ساعة)
    var cache = CacheService.getScriptCache();
    if (!cache.get('sheets_initialized')) {
      ensureAllSheets_();
      cache.put('sheets_initialized', 'true', 3600); // ساعة واحدة
    }

    const students = getStudents_();
    const rules = getRulesData_();
    const settings = getSchoolSettings_();

    // جلب المراحل المفعّلة
    var enabledStages = Object.keys(STUDENTS_SHEETS);

    return {
      success: true,
      students,
      violations: rules.violations,
      procedures: rules.procedures,
      proceduresByDegree: rules.proceduresByDegree,
      settings,
      enabledStages: enabledStages,
      source: 'dynamic'
    };
  } catch (e) {
    console.log("❌ Error in getInitialData: " + e.toString());
    return { success: false, error: e.toString() };
  }
}

// =================================================================
// HELPERS - دوال جلب الطلاب (مصححة لضبط القوائم المنسدلة)
// =================================================================
function getStudents_() {
  var allStudents = [];
  var sheets = getAllStudentsSheets_();
  
  for (var s = 0; s < sheets.length; s++) {
    var sheet = sheets[s].sheet;
    var stage = sheets[s].stage;
    
    var data = sheet.getDataRange().getValues();
    if (data.length < 2) continue;
    
    var headers = data[0];
    
    // ★ استخدام firstFound_ بدلاً من Math.max لتجنب اختيار العمود الخاطئ
    function firstFound_() {
      for (var a = 0; a < arguments.length; a++) {
        var idx = headers.indexOf(arguments[a]);
        if (idx !== -1) return idx;
      }
      return -1;
    }
    var colMap = {
      id: firstFound_('رقم الطالب', 'رقم_الطالب'),
      name: firstFound_('اسم الطالب', 'اسم_الطالب'),
      grade: firstFound_('الصف', 'رقم الصف'),
      class: firstFound_('الفصل'),
      mobile: firstFound_('رقم الجوال', 'الجوال', 'رقم_الجوال')
    };
    
    for (var i = 1; i < data.length; i++) {
      var row = data[i];
      var id = (colMap.id > -1) ? String(row[colMap.id] || '').trim() : '';
      var name = (colMap.name > -1) ? String(row[colMap.name] || '').trim() : '';
      var grade = (colMap.grade > -1) ? cleanGradeName_(row[colMap.grade]) : '';
      var cls = (colMap.class > -1) ? String(row[colMap.class] || '').trim() : '';
      var mobile = (colMap.mobile > -1) ? String(row[colMap.mobile] || '').trim() : '';
      
      if (!name) continue;
      
      allStudents.push({
        'رقم الطالب': id,
        'اسم الطالب': name,
        'الصف': grade,
        'الفصل': cls,
        'رقم الجوال': mobile,
        'المرحلة': stage
      });
    }
  }
  
  return allStudents;
}

// دالة جلب إعدادات المدرسة
function getSchoolSettings_() {
  const ss = getSpreadsheet_();
  
  // ١. جلب بيانات المنسوبين
  const sheet = ss.getSheetByName(SETTINGS_SHEET_NAME);
  const settings = { manager: '', deputies: [], counselors: [], committee: [], wakeel_name: '', wakeel_signature: '' };
  
  if (sheet && sheet.getLastRow() > 1) {
    const data = sheet.getDataRange().getValues();
    data.shift();
    data.forEach(row => {
      const category = row[0] ? row[0].toString().trim() : '';
      const role = row[1] || '';
      const name = row[2] || '';
      
      if (category === 'إدارة') settings.manager = name;
      else if (category === 'وكلاء') settings.deputies.push({ role, name });
      else if (category === 'موجهين') settings.counselors.push({ role, name });
      else if (category === 'لجنة') settings.committee.push({ role, name });
    });
  }
  
  // ٢. جلب بيانات التوقيع من نفس الشيت (العمود الأول = مفتاح، العمود الثاني = قيمة)
  // ★ إعادة استخدام نفس البيانات المقروءة أعلاه بدلاً من فتح الشيت مرة ثانية
  if (sheet && sheet.getLastRow() > 1) {
    var allData = sheet.getDataRange().getValues();
    for (var i = 1; i < allData.length; i++) {
      var key = String(allData[i][0] || '').trim();
      var val = String(allData[i][1] || '').trim();
      if (key === 'wakeel_name') settings.wakeel_name = val;
      else if (key === 'wakeel_signature') settings.wakeel_signature = val;
      else if (key === 'letterhead_mode') settings.letterhead_mode = val;
      else if (key === 'letterhead_image_url') settings.letterhead_image_url = val;
      else if (key === 'edu_admin') settings.edu_admin = val;
      else if (key === 'edu_dept') settings.edu_dept = val;
      else if (key === 'school_name') settings.school_name = val;
      else if (key === 'letterhead') settings.letterhead = val;
    }
  }
  
  return settings;
}

