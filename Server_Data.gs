  var procedures = {};
  violations.forEach(function(v) {
    procedures[v.id] = PROCEDURES_BY_DEGREE[v.degree];
  });

  return {
    violations: violations,
    procedures: procedures,
    proceduresByDegree: PROCEDURES_BY_DEGREE,
    deductionMap: DEDUCTION_BY_DEGREE
  };
}

/**
 * إرجاع الدرجة الفعلية للمخالفة حسب المرحلة
 * @param {number} violationId - رقم المخالفة
 * @param {string} stage - المرحلة ('ابتدائي' | 'متوسط' | 'ثانوي')
 * @return {number} الدرجة الفعلية
 */
// ★ كاش داخلي لخريطة المخالفات (يُبنى مرة واحدة لكل تنفيذ)
var _violationsMap = null;
function getViolationsMap_() {
  if (_violationsMap) return _violationsMap;
  var rules = getRulesData_();
  _violationsMap = {};
  for (var i = 0; i < rules.violations.length; i++) {
    _violationsMap[rules.violations[i].id] = rules.violations[i];
  }
  return _violationsMap;
}

function getEffectiveDegree_(violationId, stage) {
  var map = getViolationsMap_();
  var v = map[violationId];
  if (!v) return 1;
  if (stage === 'ابتدائي' && v.degree_ابتدائي) return v.degree_ابتدائي;
  return v.degree;
}

/**
 * إرجاع الدرجات المخصومة لمخالفة حسب رقمها ومستوى التكرار والمرحلة
 * @param {string} violationId - رقم المخالفة
 * @param {number} repeatLevel - مستوى التكرار (1، 2، 3، 4)
 * @param {string} [stage] - المرحلة (اختياري — إذا لم يُحدد يستخدم الدرجة الأساسية)
 * @return {number} الدرجات المخصومة
 */
function getDeductionForViolation_(violationId, repeatLevel, stage) {
  var effectiveDegree = getEffectiveDegree_(violationId, stage);
  var rep = repeatLevel || 1;
  var m = DEDUCTION_BY_DEGREE[effectiveDegree];
  if (!m) return 0;
  return m[rep] !== undefined ? m[rep] : 0;
}