var HIJRI_MONTHS_ = ['محرم', 'صفر', 'ربيع الأول', 'ربيع الآخر', 'جمادى الأولى', 'جمادى الآخرة', 'رجب', 'شعبان', 'رمضان', 'شوال', 'ذو القعدة', 'ذو الحجة'];

// =================================================================
// ★ تحويل ميلادي ← هجري (حساب محلي من جدول أم القرى)
// لا يعتمد على أي API خارجي
// =================================================================
function convertToHijri_(date) {
  var d = date || new Date();
  var day = d.getDate();
  var month = d.getMonth() + 1;
  var year = d.getFullYear();

  // حساب Julian Day Number
  var m = month;
  var y = year;
  if (m < 3) { y -= 1; m += 12; }
  var a = Math.floor(y / 100);
  var jgc = a - Math.floor(a / 4) - 2;
  var cjdn = Math.floor(365.25 * (y + 4716)) + Math.floor(30.6001 * (m + 1)) + day - jgc - 1524;

  // تحويل إلى Modified CJDN
  var mcjdn = cjdn - 2400000;

  // البحث في جدول أم القرى
  var i;
  for (i = 0; i < UMMALQURA_DAT_.length; i++) {
    if (UMMALQURA_DAT_[i] > mcjdn) break;
  }

  // حساب التاريخ الهجري
  var iln = i + 16260;
  var ii = Math.floor((iln - 1) / 12);
  var hijriYear = ii + 1;
  var hijriMonth = iln - 12 * ii;
  var hijriDay = mcjdn - UMMALQURA_DAT_[i - 1] + 1;

  return {
    day: hijriDay,
    month: hijriMonth,
    year: hijriYear,
    monthName: HIJRI_MONTHS_[hijriMonth - 1] || ''
  };
}

// =================================================================
// ★ دالة التاريخ الهجري المركزية (المصدر الوحيد)
// المصدر: جدول تقويم أم القرى الرسمي (ummulqura.org.sa) — حساب محلي
// =================================================================
function getHijriDate_(date) {
  try {
    var h = convertToHijri_(date);
    return h.year + '/' + h.month + '/' + h.day;
  } catch (e) {
    return Utilities.formatDate(date || new Date(), Session.getScriptTimeZone(), 'yyyy/MM/dd');
  }
}

// ★ استخراج التاريخ الهجري من خلية — يتعامل مع Date الذي حوّله Sheets تلقائياً
// إذا السنة بين 1300-1500 فهو هجري أصلاً (Sheets فسّره كميلادي بالخطأ) → نستخرج الأرقام مباشرة
// إذا السنة ميلادية حديثة (1900+) → نحوّل من ميلادي لهجري
function readHijriCellValue_(val) {
  if (!val) return '';
  if (typeof val === 'string') {
    // تواريخ نصية قديمة بصيغة يوم/شهر/سنة → قلبها لـ سنة/شهر/يوم
    var m = val.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
    if (m && parseInt(m[3]) >= 1300 && parseInt(m[3]) <= 1500) {
      return m[3] + '/' + m[2] + '/' + m[1];
    }
    return val;
  }
  if (val instanceof Date) {
    var y = val.getFullYear();
    if (y >= 1300 && y <= 1500) {
      // هجري أصلاً — Sheets حوّله لـ Date بالخطأ
      return y + '/' + (val.getMonth() + 1) + '/' + val.getDate();
    }
    // تاريخ ميلادي حديث → تحويل لهجري
    try { return getHijriDate_(val); } catch(e) { return String(val); }
  }
  return String(val);
}

// ★ جلب التاريخ الهجري الكامل (مع اسم الشهر) — للداشبورد
function getHijriDateFull_(date) {
  try {
    var d = date || new Date();
    var h = convertToHijri_(d);
    var gregMonths = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    return {
      hijriDay: h.day,
      hijriMonth: h.monthName,
      hijriMonthNum: h.month,
      hijriYear: h.year,
      hijriStr: h.day + ' ' + h.monthName + ' ' + h.year + ' هـ',
      gregorianStr: d.getDate() + ' ' + gregMonths[d.getMonth()] + ' ' + d.getFullYear(),
      weekdayAr: getDayNameAr_(d)
    };
  } catch(e) { return {hijriStr: '', gregorianStr: '', weekdayAr: ''}; }
}

// =================================================================
// ★ اسم اليوم بالعربي (مركزية)
// =================================================================
function getDayNameAr_(date) {
  var days = ['الأحد', 'الاثنين', 'الثلاثاء', 'الأربعاء', 'الخميس', 'الجمعة', 'السبت'];
  return days[(date || new Date()).getDay()];
}

