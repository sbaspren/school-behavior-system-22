// getSheetName_('التأخر', 'ثانوي') → 'سجل_التأخر_ثانوي'
// =================================================================
function getSheetName_(type, stage) {
  var entry = SHEET_REGISTRY[type];
  if (!entry) {
    Logger.log('⚠️ نوع شيت غير معروف: ' + type);
    return 'سجل_' + type + '_' + stage;
  }
  return entry.prefix + '_' + stage;
}

